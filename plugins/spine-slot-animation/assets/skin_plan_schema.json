{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://h5g.local/schemas/spine_slot_animation_skin_plan_v1.json",
  "title": "Reviewed Spine 4.2 Multi-Skin Region Variant Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "skins"],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_skin_plan_v1"
    },
    "skins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "attachments"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "not": { "const": "default" },
            "description": "Unique non-default skin name. The compiler always emits the default skin first."
          },
          "attachments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target_slot", "attachment_key", "path"],
              "oneOf": [
                { "required": ["source_layer"], "not": { "required": ["layer_file"] } },
                { "required": ["layer_file"], "not": { "required": ["source_layer"] } }
              ],
              "properties": {
                "source_layer": {
                  "type": "string",
                  "minLength": 1,
                  "description": "PNG source layer name or stem resolved under layer_dir."
                },
                "layer_file": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Explicit relative PNG path under layer_dir, such as variants/body_gold.png."
                },
                "target_slot": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Existing slot that receives this skin variant attachment."
                },
                "attachment_key": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Skin attachment map key. Must match the default attachment key for target_slot to preserve fallback."
                },
                "attachment_name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Optional reviewed display/name metadata; Spine lookup still uses attachment_key."
                },
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Atlas region path for this skin variant image."
                },
                "type": {
                  "const": "region",
                  "description": "Phase 6 supports region attachments only. Linked meshes are intentionally not implemented."
                },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "width": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "height": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          },
          "bones": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Optional existing bone names that are skin-specific in Spine membership."
          },
          "constraints": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ik": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "transform": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "path": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "physics": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
