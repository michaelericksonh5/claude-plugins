{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://h5g.local/schemas/spine_slot_animation_avatar_runtime_contract_v1.json",
  "title": "Avatar Runtime Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "avatar_id",
    "runtime_owner",
    "default_state",
    "states",
    "events",
    "runtime_acceptance"
  ],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_avatar_runtime_contract_v1"
    },
    "avatar_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime_owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["team", "approver"],
      "properties": {
        "team": { "type": "string", "minLength": 1 },
        "approver": { "type": "string", "minLength": 1 }
      }
    },
    "default_state": {
      "type": "integer",
      "minimum": 0
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "idle_animation"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "idle_animation": { "type": "string", "minLength": 1 },
          "awarded_animation": { "type": "string", "minLength": 1 },
          "close_animation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "animation"],
        "properties": {
          "from": { "type": "integer", "minimum": 0 },
          "to": { "type": "integer", "minimum": 0 },
          "animation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "animation", "time", "consumer"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "animation": { "type": "string", "minLength": 1 },
          "time": { "type": "number", "minimum": 0 },
          "consumer": { "type": "string", "minLength": 1 }
        }
      }
    },
    "runtime_acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_runtime", "verified"],
      "properties": {
        "target_runtime": { "type": "string", "minLength": 1 },
        "verified": { "type": "boolean" },
        "evidence": { "type": "string" }
      }
    }
  }
}
