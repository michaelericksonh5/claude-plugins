{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Avatar State Manifest",
  "description": "Sidecar state graph emitted for avatar proof packages. The game runtime owns persistent state and event consumption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "default_state",
    "states",
    "transitions",
    "awarded_beats",
    "close_beats",
    "animations",
    "event_names",
    "event_timelines_emitted",
    "expression_support",
    "physics_candidates",
    "physics_support",
    "ik_support",
    "runtime_required",
    "runtime_consumer_verified",
    "persistent_state_owner",
    "persistent_state_claimed_in_spine",
    "persistent_state_claimed",
    "preview_required",
    "art_approval_required",
    "art_approval_claimed",
    "issues"
  ],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_avatar_state_manifest_v1"
    },
    "default_state": {
      "type": ["string", "null"],
      "pattern": "^state_[0-9]+$"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "index", "slot", "attachment", "idle_animation", "awarded_animation", "close_animation"],
        "properties": {
          "id": {"type": "string", "pattern": "^state_[0-9]+$"},
          "index": {"type": "integer", "minimum": 0},
          "slot": {"type": "string", "minLength": 1},
          "attachment": {"type": "string", "pattern": "^parts/.+"},
          "idle_animation": {"type": "string", "pattern": "^State[0-9]+Idle$"},
          "awarded_animation": {"type": ["string", "null"], "pattern": "^State[0-9]+Awarded$"},
          "close_animation": {"type": ["string", "null"], "pattern": "^State[0-9]+Close$"}
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {"$ref": "#/definitions/transition"}
    },
    "awarded_beats": {
      "type": "array",
      "items": {"$ref": "#/definitions/stateBeat"}
    },
    "close_beats": {
      "type": "array",
      "items": {"$ref": "#/definitions/stateBeat"}
    },
    "animations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boot", "idles", "transitions", "awarded", "close"],
      "properties": {
        "boot": {"type": ["string", "null"]},
        "idles": {"type": "array", "items": {"type": "string"}},
        "transitions": {"type": "array", "items": {"type": "string"}},
        "awarded": {"type": "array", "items": {"type": "string"}},
        "close": {"type": "array", "items": {"type": "string"}}
      }
    },
    "event_names": {
      "type": "array",
      "items": {"type": "string", "pattern": "^avatar/state_[0-9]+(_awarded|_close|_to_[0-9]+)$"},
      "uniqueItems": true
    },
    "event_timelines_emitted": {"type": "boolean"},
    "expression_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "composite_expressions_enabled", "composited_expressions", "preview_required", "art_approval_required", "art_approval_claimed"],
      "properties": {
        "status": {"enum": ["not_requested", "composited_expression_proof"]},
        "composite_expressions_enabled": {"type": "boolean"},
        "composited_expressions": {"type": "array", "items": {"type": "string"}},
        "preview_required": {"type": "boolean"},
        "art_approval_required": {"type": "boolean"},
        "art_approval_claimed": {"const": false}
      }
    },
    "physics_candidates": {"type": "array", "items": {"type": "object"}},
    "physics_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "enabled", "candidate_count", "constraints_emitted", "preview_required", "art_approval_required", "art_approval_claimed"],
      "properties": {
        "status": {"enum": ["not_requested", "enabled_no_candidates", "candidates_reported", "constraints_emitted_review_required"]},
        "enabled": {"type": "boolean"},
        "candidate_count": {"type": "integer", "minimum": 0},
        "constraints_emitted": {"type": "integer", "minimum": 0},
        "preview_required": {"type": "boolean"},
        "art_approval_required": {"type": "boolean"},
        "art_approval_claimed": {"const": false}
      }
    },
    "ik_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "enabled", "candidate_count", "constraints_emitted", "art_approval_required", "production_approval_claimed"],
      "properties": {
        "status": {"enum": ["not_requested", "enabled_no_candidates", "candidates_reported", "constraints_emitted_review_required"]},
        "enabled": {"type": "boolean"},
        "candidate_count": {"type": "integer", "minimum": 0},
        "constraints_emitted": {"type": "integer", "minimum": 0},
        "art_approval_required": {"type": "boolean"},
        "production_approval_claimed": {"const": false}
      }
    },
    "runtime_required": {"const": true},
    "runtime_consumer_verified": {"const": false},
    "persistent_state_owner": {"const": "game_runtime"},
    "persistent_state_claimed_in_spine": {"const": false},
    "persistent_state_claimed": {"const": false},
    "preview_required": {"type": "boolean"},
    "art_approval_required": {"type": "boolean"},
    "art_approval_claimed": {"const": false},
    "issues": {"type": "array", "items": {"type": "string"}}
  },
  "definitions": {
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_state", "to_state", "animation", "slot", "attachment", "event_name", "event_time"],
      "properties": {
        "from_state": {"type": "string", "pattern": "^state_[0-9]+$"},
        "to_state": {"type": "string", "pattern": "^state_[0-9]+$"},
        "animation": {"type": "string", "pattern": "^State[0-9]+to[0-9]+$"},
        "slot": {"type": "string", "minLength": 1},
        "attachment": {"type": "string", "pattern": "^parts/.+"},
        "event_name": {"type": "string", "pattern": "^avatar/state_[0-9]+_to_[0-9]+$"},
        "event_time": {"type": "number", "minimum": 0}
      }
    },
    "stateBeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "animation", "slot", "attachment", "event_name", "event_time"],
      "properties": {
        "state": {"type": "string", "pattern": "^state_[0-9]+$"},
        "animation": {"type": "string", "pattern": "^State[0-9]+(Awarded|Close)$"},
        "slot": {"type": "string", "minLength": 1},
        "attachment": {"type": "string", "pattern": "^parts/.+"},
        "event_name": {"type": "string", "pattern": "^avatar/state_[0-9]+_(awarded|close)$"},
        "event_time": {"type": "number", "minimum": 0}
      }
    }
  }
}
