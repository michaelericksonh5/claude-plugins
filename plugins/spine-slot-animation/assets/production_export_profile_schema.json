{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://h5g.local/schemas/spine_slot_animation_production_export_profile_v1.json",
  "title": "Spine Slot Animation Production Export Gate Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "spine_editor_version",
    "spine_cli_version",
    "runtime",
    "output_format",
    "license_posture",
    "write_policy",
    "advanced_features",
    "runtime_acceptance_evidence",
    "approver",
    "production_export_approval"
  ],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_production_export_profile_v1"
    },
    "package_validation_report": {
      "type": "string",
      "minLength": 1,
      "description": "Optional path to validation_report.json. If omitted, the gate reads <package-dir>/validation_report.json."
    },
    "spine_editor_version": {
      "type": "string",
      "pattern": "^4\\.3\\.04$"
    },
    "spine_cli_version": {
      "type": "string",
      "pattern": "^4\\.3\\.04$"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "const": "@esotericsoftware/spine-player"
        },
        "version": {
          "pattern": "^4\\.3\\.1$",
          "type": "string"
        }
      }
    },
    "output_format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rationale"],
      "properties": {
        "decision": {
          "enum": ["json", "binary"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "license_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved", "approval_ticket", "approved_by", "approved_at"],
      "properties": {
        "approved": {
          "const": true
        },
        "approval_ticket": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "write_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["perforce_writes", "source_art_writes"],
      "properties": {
        "perforce_writes": {
          "const": false
        },
        "source_art_writes": {
          "const": false
        }
      }
    },
    "advanced_features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimed_counts"],
      "properties": {
        "claimed_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["skins", "physics", "sequences", "clipping", "events", "blends"],
          "properties": {
            "skins": { "type": "integer", "minimum": 0 },
            "physics": { "type": "integer", "minimum": 0 },
            "sequences": { "type": "integer", "minimum": 0 },
            "clipping": { "type": "integer", "minimum": 0 },
            "events": { "type": "integer", "minimum": 0 },
            "blends": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "runtime_acceptance_evidence": {
      "type": "string",
      "minLength": 1,
      "description": "Path to runtime acceptance evidence JSON with approved runtime-probe provenance and current package hashes. The gate resolves relative paths from the profile directory."
    },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "approved_at", "approval_ticket"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "minLength": 1 },
        "approval_ticket": { "type": "string", "minLength": 1 }
      }
    },
    "production_export_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manual_export_approved", "cli_invocation_approved"],
      "properties": {
        "manual_export_approved": { "const": true },
        "cli_invocation_approved": { "type": "boolean" }
      }
    }
  }
}
