{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://h5g.local/schemas/spine_slot_animation_mesh_weight_parity_fixture_v1.json",
  "title": "Mesh Weight Parity Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fixture_id",
    "approved_spine_export",
    "candidate_spine_json",
    "thresholds",
    "approval"
  ],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_mesh_weight_parity_fixture_v1"
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "approved_spine_export": {
      "type": "string",
      "minLength": 1
    },
    "candidate_spine_json": {
      "type": "string",
      "minLength": 1
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_exact_vertex_count",
        "require_exact_triangle_count",
        "max_weight_sum_error",
        "max_bones_per_vertex"
      ],
      "properties": {
        "require_exact_vertex_count": { "type": "boolean" },
        "require_exact_triangle_count": { "type": "boolean" },
        "max_weight_sum_error": { "type": "number", "minimum": 0 },
        "max_bones_per_vertex": { "type": "integer", "minimum": 1 }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approved_by", "approved_at", "notes"],
      "properties": {
        "approved_by": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
