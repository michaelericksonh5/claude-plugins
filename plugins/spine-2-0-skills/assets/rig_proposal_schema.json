{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://h5g.local/schemas/spine_slot_animation_rig_proposal_v1.json",
  "title": "Report-Only Rig Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "proposal_mode",
    "production_output_claimed",
    "asset",
    "evidence_support",
    "confidence",
    "region_decisions",
    "mesh_decisions",
    "review",
    "policy_gates",
    "source_policy"
  ],
  "properties": {
    "schema": {
      "const": "spine_slot_animation_rig_proposal_v1"
    },
    "proposal_mode": {
      "const": "report_only"
    },
    "production_output_claimed": {
      "const": false
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "source_summary"],
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "source_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall", "basis", "review_reasons"],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "basis": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "review_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_index", "support_status", "evidence_ids"],
      "properties": {
        "evidence_index": {
          "const": "assets/h5g_corpus_distilled_evidence.json"
        },
        "support_status": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^assets/h5g_corpus_distilled_evidence\\.json:"
          }
        }
      }
    },
    "region_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/attachment_decision" }
    },
    "mesh_decisions": {
      "type": "array",
      "items": { "$ref": "#/$defs/mesh_decision" }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reasons", "approved_by"],
      "properties": {
        "required": { "const": true },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "approved_by": { "const": null }
      }
    },
    "policy_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spine_auto_weight_parity_fixture",
        "chris_approved_mesh_fixture",
        "avatar_runtime_state_contract",
        "production_export_policy",
        "target_runtime_acceptance",
        "final_autonomous_rigger_claim"
      ],
      "properties": {
        "spine_auto_weight_parity_fixture": { "$ref": "#/$defs/gate" },
        "chris_approved_mesh_fixture": { "$ref": "#/$defs/gate" },
        "avatar_runtime_state_contract": { "$ref": "#/$defs/gate" },
        "production_export_policy": { "$ref": "#/$defs/gate" },
        "target_runtime_acceptance": { "$ref": "#/$defs/gate" },
        "final_autonomous_rigger_claim": { "$ref": "#/$defs/gate" }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_inputs", "prohibited_writes", "external_code_policy"],
      "properties": {
        "allowed_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "prohibited_writes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "external_code_policy": {
          "const": "Genielabs concepts may inform review questions; PolyForm Noncommercial code must not be copied or embedded."
        }
      }
    }
  },
  "$defs": {
    "attachment_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "attachment_type", "confidence", "reason"],
      "properties": {
        "layer": { "type": "string", "minLength": 1 },
        "attachment_type": { "const": "region" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "mesh_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer",
        "attachment_type",
        "confidence",
        "review_required",
        "review_reasons",
        "weight_strategy",
        "deform_strategy"
      ],
      "properties": {
        "layer": { "type": "string", "minLength": 1 },
        "attachment_type": { "const": "mesh_candidate" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_required": { "const": true },
        "review_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "weight_strategy": {
          "enum": ["first_pass_review_only", "manual_spine_editor_required"]
        },
        "deform_strategy": {
          "const": "avoid_deform_keys_until_reviewed_corrective_case"
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_evidence"],
      "properties": {
        "status": {
          "enum": ["missing", "blocked", "manual_review_required", "verified"]
        },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
