# Copy this file to .env and fill in your key(s).
# Run `node setup-keys.js` to do this interactively (input is hidden).
#
# This plugin uses two independent model families:
#
#   NB2 family (Nano Banana 2) — 4 tools:
#     nb2_generate, nb2_edit, nb2_upscale, nb2_smart_resize
#     Powered by GEMINI_API_KEY and/or FAL_KEY (either alone works; both
#     gives each tool its strongest backend).
#
#   GPT Image 2 family — 2 tools:
#     gpt2_generate, gpt2_edit  (at 1K or 2K)
#     Powered by OPENAI_API_KEY. Strong text rendering, stable 2K
#     photorealism, multi-image composition. For genuine 4K marketing
#     output: generate at 2K then run nb2_upscale (tested path).
#     Use for hero / text-heavy assets. More expensive than NB2.
#
# Routing when both NB2 keys are set:
#   nb2_generate / nb2_edit / nb2_upscale → Gemini (direct API, one fewer hop)
#   nb2_smart_resize                       → Gemini (NB2 + local pngjs crop)
#
# Google AI Studio / Gemini key
#   Get a key at https://aistudio.google.com/apikey
#   Run:  node setup-keys.js --gemini
GEMINI_API_KEY=
#
# fal.ai key
#   Get a key at https://fal.ai/dashboard
#   Run:  node setup-keys.js --fal
FAL_KEY=
#
# OpenAI key (optional — only needed for gpt2_generate / gpt2_edit)
#   Get a key at https://platform.openai.com/api-keys
#   Run:  node setup-keys.js --openai
OPENAI_API_KEY=
#
# At least one of GEMINI_API_KEY or FAL_KEY is required for the NB2 tools.
# OPENAI_API_KEY is optional and only powers the gpt2_* tools.
#
# Optional corporate network settings:
#   HTTPS_PROXY / HTTP_PROXY / NO_PROXY are honored by the MCP server.
#   NODE_EXTRA_CA_CERTS or SSL_CERT_FILE can point to a PEM bundle when
#   corporate HTTPS inspection requires Node to trust an internal root CA.
#   Example Windows path: C:\Users\you\corp-ca-bundle.pem
#   Example macOS path:   /Users/you/corp-ca-bundle.pem
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=
NODE_EXTRA_CA_CERTS=
SSL_CERT_FILE=
